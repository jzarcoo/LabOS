sys_gpio_get:
    @ r0: pin (Argument 1)
    @ Save r7 in r12 to avoid modifying user stack
    mov r12, r7
    movs r7, #SYS_GPIO_GET @ Load syscall ID (2)
    svc #0              @ Kernel will place the result in r0
    mov r7, r12
    bx lr#include <stdint.h>
